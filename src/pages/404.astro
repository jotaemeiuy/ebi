---
import Layout from '../layouts/Layout.astro';

const { pathname } = Astro.url;
const isLesson = pathname.includes('/unidad/') && pathname.split('/').length > 3;
---

<Layout title="Página no encontrada - EBI 9C">
  <div class="min-h-[60vh] flex items-center justify-center py-20">
    <div class="text-center max-w-md mx-auto px-4">
      <div class="w-20 h-20 mx-auto mb-6 rounded-2xl bg-slate-800 flex items-center justify-center">
        <span class="text-4xl">🔍</span>
      </div>
      
      <h1 class="text-3xl font-bold text-slate-100 mb-4">
        {isLesson ? 'Lección en preparación' : 'Página no encontrada'}
      </h1>
      
      <p class="text-slate-400 mb-2">
        {isLesson 
          ? 'Esta lección aún no está disponible. Estamos trabajando en el contenido.'
          : 'La página que buscás no existe o fue movida.'
        }
      </p>
      
      {isLesson && (
        <p class="text-violet-400 text-sm mb-8">
          Podés volver a la unidad para ver las lecciones disponibles.
        </p>
      )}
      
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        {isLesson ? (
          <a 
            href={pathname.split('/').slice(0, 3).join('/')}
            class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-lg bg-violet-600 hover:bg-violet-500 text-white transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
            Ver unidad
          </a>
        ) : (
          <a 
            href="/"
            class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-lg bg-violet-600 hover:bg-violet-500 text-white transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            Ir al inicio
          </a>
        )}
        <a 
          href="javascript:history.back()"
          class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-lg bg-slate-800 hover:bg-slate-700 text-slate-300 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Volver atrás
        </a>
      </div>
    </div>
  </div>
</Layout>
