---
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  const units = [
    {
      id: 1,
      title: "Números y Finanzas",
      description: "Notación científica, porcentajes e interés simple y compuesto",
      lessons: [
        { title: "Notación científica", slug: "notacion-cientifica" },
        { title: "Porcentajes y porcentajes encadenados", slug: "porcentajes" },
        { title: "Interés simple", slug: "interes-simple" },
        { title: "Interés compuesto", slug: "interes-compuesto" }
      ],
      pdfs: []
    },
    {
      id: 2,
      title: "Estadística y Probabilidad",
      description: "Gráficos estadísticos, medidas de tendencia central y probabilidad",
      lessons: [
        { title: "Gráficos estadísticos", slug: "graficos" },
        { title: "Media, mediana y moda", slug: "medidas-tendencia" },
        { title: "Probabilidad", slug: "probabilidad" }
      ],
      pdfs: []
    },
    {
      id: 3,
      title: "Álgebra",
      description: "Productos notables y factorización de expresiones algebraicas",
      lessons: [
        { title: "Productos notables", slug: "productos-notables" },
        { title: "Factorización", slug: "factorizacion" }
      ],
      pdfs: []
    },
    {
      id: 4,
      title: "Ecuaciones",
      description: "Ecuaciones cuadráticas y sistemas de ecuaciones",
      lessons: [
        { title: "Ecuaciones cuadráticas", slug: "ecuaciones-cuadraticas" },
        { title: "Sistemas de ecuaciones", slug: "sistemas-ecuaciones" }
      ],
      pdfs: []
    },
    {
      id: 5,
      title: "Funciones",
      description: "Función cuadrática y su representación gráfica",
      lessons: [
        { title: "Función cuadrática", slug: "funcion-cuadratica" },
        { title: "Representación gráfica", slug: "representacion-grafica" }
      ],
      pdfs: []
    }
  ];

  return units.map(unit => ({
    params: { id: unit.id.toString() },
    props: { unit }
  }));
}

const { unit } = Astro.props;
---

<Layout title={`${unit.title} - EBI 9C`} description={unit.description}>
  <div class="py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8">
        <a href="/" class="hover:text-violet-400 transition-colors">Inicio</a>
        <span>/</span>
        <span class="text-slate-300">Unidad {unit.id}</span>
      </nav>

      <!-- Header -->
      <div class="mb-12">
        <span class="inline-flex items-center px-3 py-1 rounded-full bg-violet-500/10 text-violet-400 text-sm font-medium mb-4">
          Unidad {unit.id}
        </span>
        <h1 class="text-4xl font-bold text-slate-100 mb-4">{unit.title}</h1>
        <p class="text-lg text-slate-400">{unit.description}</p>
      </div>

      <!-- Lecciones -->
      <section class="mb-12">
        <h2 class="text-2xl font-semibold text-slate-100 mb-6 flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
          Lecciones
        </h2>
        
        <div class="grid gap-4">
          {unit.lessons.map((lesson, index) => (
            <a 
              href={`/unidad/${unit.id}/${lesson.slug}`}
              class="group flex items-center gap-4 p-4 rounded-xl bg-slate-900/50 border border-slate-800 hover:border-violet-500/50 transition-all"
            >
              <div class="w-10 h-10 rounded-lg bg-violet-500/10 flex items-center justify-center text-violet-400 font-semibold">
                {index + 1}
              </div>
              <div class="flex-1">
                <h3 class="font-medium text-slate-100 group-hover:text-violet-300 transition-colors">
                  {lesson.title}
                </h3>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-500 group-hover:text-violet-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          ))}
        </div>
      </section>

      <!-- Materiales PDF -->
      <section>
        <h2 class="text-2xl font-semibold text-slate-100 mb-6 flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
          </svg>
          Materiales PDF
        </h2>
        
        {unit.pdfs.length > 0 ? (
          <div class="grid gap-4">
            {unit.pdfs.map((pdf) => (
              <a 
                href={pdf.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-center gap-4 p-4 rounded-xl bg-slate-900/50 border border-slate-800 hover:border-violet-500/50 transition-all"
              >
                <div class="w-10 h-10 rounded-lg bg-red-500/10 flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                  </svg>
                </div>
                <div class="flex-1">
                  <h3 class="font-medium text-slate-100">{pdf.title}</h3>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            ))}
          </div>
        ) : (
          <div class="p-6 rounded-xl bg-slate-900/30 border border-slate-800/50 text-center">
            <p class="text-slate-500">Los materiales PDF se agregarán próximamente.</p>
          </div>
        )}
      </section>

      <!-- Volver -->
      <div class="mt-12">
        <a 
          href="/"
          class="inline-flex items-center gap-2 text-slate-400 hover:text-violet-400 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Volver al inicio
        </a>
      </div>
    </div>
  </div>
</Layout>
