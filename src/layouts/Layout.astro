---
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "EBI - UTU Arroyo Seco",
	description = "Material de matemática para 9°C",
} = Astro.props;
---

<!doctype html>
<html lang="es" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="description" content={description} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="bg-slate-950 text-slate-100 font-sans antialiased">
		<nav
			class="sticky top-0 z-50 backdrop-blur-lg bg-slate-950/80 border-b border-slate-800"
		>
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="flex items-center justify-between h-16">
					<a
						href="/"
						class="flex items-center gap-2 font-bold text-xl"
					>
						<span class="text-violet-400">EBI Arroyo Seco</span>
						<span class="text-slate-100">9°</span>
					</a>
					<div
						class="hidden sm:flex items-center gap-6 text-sm font-medium"
					>
						<a
							href="/"
							class="text-slate-300 hover:text-violet-400 transition-colors"
							>Inicio</a
						>
						<a
							href="/#unidades"
							class="text-slate-300 hover:text-violet-400 transition-colors"
							>Unidades</a
						>
					</div>
				</div>
			</div>
		</nav>
		<main>
			<slot />
		</main>
		<footer class="border-t border-slate-800 bg-slate-950 py-8 mt-20">
			<div
				class="max-w-7xl mx-auto px-4 text-center text-slate-400 text-sm"
			>
				<p>EBI - Matemática | UTU Arroyo Seco</p>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	html {
		font-family: "Inter", system-ui, sans-serif;
	}
</style>
