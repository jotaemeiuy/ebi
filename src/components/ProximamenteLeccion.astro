---
interface Props {
  title: string;
  unitId: number;
  unitTitle: string;
}

const { title, unitId, unitTitle } = Astro.props;
---

<div class="min-h-[50vh] flex items-center justify-center">
  <div class="text-center max-w-lg mx-auto">
    <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-violet-500/10 flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
      </svg>
    </div>
    
    <h2 class="text-2xl font-bold text-slate-100 mb-3">{title}</h2>
    <p class="text-slate-400 mb-6">
      Esta lección está en preparación. El contenido estará disponible próximamente.
    </p>
    
    <a 
      href={`/unidad/${unitId}`}
      class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-violet-600 hover:bg-violet-500 text-white transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
      </svg>
      Volver a {unitTitle}
    </a>
  </div>
</div>
